{
  "name": "particle-model-studio",
  "version": "1.0.5",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "electron": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win dir --x64",
    "dist:win:portable": "npm run build && electron-builder --win portable --x64",
    "export:mov": "node scripts/export-mov.js",
    "test:smoke": "node scripts/smoke-test.js",
    "test:electron": "node scripts/electron-smoke-test.js",
    "test:electron:packaged": "node scripts/electron-smoke-test.js --packaged",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@mkkellogg/gaussian-splats-3d": "^0.4.7",
    "ffmpeg-static": "^5.3.0",
    "lucide": "^0.468.0",
    "three": "^0.164.1"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.particlemodel.studio",
    "productName": "Particle Model Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/ffmpeg-static/**/*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "extraResources": [
      {
        "from": "tools/ml-sharp",
        "to": "tools/ml-sharp",
        "filter": [
          "README.md",
          "run-sharp.py"
        ]
      },
      {
        "from": "tools/spatial-media",
        "to": "tools/spatial-media",
        "filter": [
          "README.md",
          "LICENSE-spatial-media.txt",
          "Spatial Media Metadata Injector.exe"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
